@inject NavigationManager Nav

<div class="bg-slate-900 border-b border-slate-800 px-6 py-4">
    <a href="" class="flex items-center gap-3">
        <div class="w-10 h-10 bg-emerald-500 rounded-lg flex items-center justify-center">
            <i class="bi bi-calculator-fill text-white"></i>
        </div>
        <span class="text-xl font-bold text-white">
            Economic<span class="text-emerald-500">App</span>
        </span>
    </a>
</div>

<nav class="flex flex-col px-4 py-6 space-y-1">
    <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider px-3 mb-2">General</div>
    
    <a href="" 
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors"
        @onclick="CerrarYSaltar">
        <i class="bi bi-house-fill"></i>
        <span>Inicio</span>
    </a>

    <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider px-3 mt-6 mb-2">Operaciones</div>

    <a href="simulador" 
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors"
        @onclick="CerrarYSaltar">
        <i class="bi bi-calculator"></i>
        <span>Simulador Créditos</span>
    </a>

    <a href="razones" 
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors"
        @onclick="CerrarYSaltar">
        <i class="bi bi-arrow-left-right"></i>
        <span>Razones y Prop.</span>
    </a>
</nav>

@code {
    [CascadingParameter] private bool IsSidebarOpen { get; set; }
    [CascadingParameter] private Action ToggleSidebar { get; set; } = () => { };

    private void CerrarYSaltar()
    {
        if (IsSidebarOpen)
        {
            ToggleSidebar();
        }
    }
}