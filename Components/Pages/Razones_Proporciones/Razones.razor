@page "/razones"
@rendermode InteractiveServer

<div class="animate-fadeIn max-w-5xl mx-auto">
    <div class="mb-8">
        <h2 class="text-2xl font-bold text-white flex items-center gap-3 mb-2">
            <i class="bi bi-diagram-3-fill text-emerald-500"></i>
            Módulo de Reparto Proporcional
        </h2>
        <p class="text-slate-400">Seleccione el método de distribución que desea aplicar según el enunciado del problema.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <button @onclick='() => Navegar("razones/metodo-1")' class="group bg-slate-800 border border-slate-700 rounded-2xl p-6 text-left hover:border-emerald-500 transition-all duration-300 hover:-translate-y-1">
            <div class="w-14 h-14 bg-emerald-500/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-emerald-500/20 transition-colors">
                <i class="bi bi-grid-3x3-gap text-2xl text-emerald-500"></i>
            </div>
            <h3 class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Método 1</h3>
            <h5 class="text-white font-semibold mb-2">Proporciones</h5>
            <p class="text-slate-400 text-sm mb-4">Reparto simple basado en la constante de proporcionalidad K.</p>
            <span class="inline-flex items-center gap-1 text-emerald-500 text-sm font-semibold">
                Disponible <i class="bi bi-arrow-right"></i>
            </span>
        </button>

        <button @onclick='() => Navegar("razones/metodo-2")' class="group bg-slate-800 border border-slate-700 rounded-2xl p-6 text-left hover:border-emerald-500 transition-all duration-300 hover:-translate-y-1">
            <div class="w-14 h-14 bg-emerald-500/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-emerald-500/20 transition-colors">
                <i class="bi bi-bounding-box text-2xl text-emerald-500"></i>
            </div>
            <h3 class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Método 2</h3>
            <h5 class="text-white font-semibold mb-2">Reducción a la Unidad</h5>
            <p class="text-slate-400 text-sm mb-4">Lógica de cálculo basada en el valor unitario de los índices.</p>
            <span class="inline-flex items-center gap-1 text-emerald-500 text-sm font-semibold">
                Disponible <i class="bi bi-arrow-right"></i>
            </span>
        </button>

        <button @onclick='() => Navegar("razones/metodo-3")' class="group bg-slate-800 border border-slate-700 rounded-2xl p-6 text-left hover:border-emerald-500 transition-all duration-300 hover:-translate-y-1">
            <div class="w-14 h-14 bg-emerald-500/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-emerald-500/20 transition-colors">
                <i class="bi bi-pie-chart-fill text-2xl text-emerald-500"></i>
            </div>
            <h3 class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Método 3</h3>
            <h5 class="text-white font-semibold mb-2">Partes Alícuotas</h5>
            <p class="text-slate-400 text-sm mb-4">Distribución de montos mediante fracciones proporcionales.</p>
            <span class="inline-flex items-center gap-1 text-emerald-500 text-sm font-semibold">
                Disponible <i class="bi bi-arrow-right"></i>
            </span>
        </button>
    </div>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;
    private void Navegar(string url) => Nav.NavigateTo(url);
}