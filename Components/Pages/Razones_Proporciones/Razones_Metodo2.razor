@page "/razones/metodo-2"
@using System.Globalization
@rendermode InteractiveServer

<div class="animate-fadeIn">
    <!-- Encabezado -->
    <div class="d-flex align-items-center mb-4">
        <a href="razones" class="btn btn-outline-secondary btn-sm me-3">
            <i class="bi bi-arrow-left"></i> Volver al Menú
        </a>
        <h3 class="text-emerald fw-bold mb-0">Método 2: Reducción a la Unidad</h3>
    </div>

    <div class="row">
        <!-- Panel de Configuración -->
        <div class="col-lg-4">
            <div class="content-card mb-4">
                <h4 class="mb-4 text-white"><i class="bi bi-input-cursor-text me-2"></i>Entrada de Datos</h4>

                <div class="form-group mb-4">
                    <label class="text-muted small fw-bold">CANTIDAD A REPARTIR (COP)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary text-emerald">$</span>
                        <input type="number" class="form-control" @bind="montoTotal" @bind:event="oninput" />
                    </div>
                    <small class="text-muted mt-1 d-block">Monto total a distribuir.</small>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <label class="text-muted small fw-bold">ÍNDICES DE REPARTO</label>
                    <button class="btn btn-sm btn-outline-emerald" @onclick="AgregarIndividuo">
                        <i class="bi bi-plus-lg"></i> Nuevo Índice
                    </button>
                </div>

                <div class="scroll-area">
                    @for (int i = 0; i < individuos.Count; i++)
                    {
                        var index = i;
                        <div class="individuo-item mb-2 animate-fadeIn">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-dark border-secondary text-muted">ID @(index + 1)</span>
                                <input type="number" class="form-control" @bind="individuos[index].Indice" @bind:event="oninput" placeholder="Valor" />
                                <button class="btn btn-outline-danger border-secondary" @onclick="() => EliminarIndividuo(index)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Panel de Fórmulas Estilizadas -->
            <div class="content-card formula-display">
                <h5 class="text-emerald mb-4 text-center border-bottom border-secondary pb-2">
                    <i class="bi bi-function me-2"></i>Formulas Implementadas
                </h5>

                <!-- Fórmula Fc -->
                <div class="math-container mb-4">
                    <div class="math-label text-muted">Factor de Conversión:</div>
                    <div class="math-formula">
                        <span class="var">F<sub>c</sub></span> = 
                        <span class="num">Monto Total / </span>
                        <span class="den">Σ Índices</span>
                        <div class="fraction">
                            
                        </div>
                    </div>
                </div>

                <!-- Fórmula Cociente -->
                <div class="math-container">
                    <div class="math-label text-muted">Cociente Individual:</div>
                    <div class="math-formula">
                        <span class="var">C<sub>n</sub></span> =
                        <span class="var">Índice<sub>n</sub></span> × <span class="var">F<sub>c</sub></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel de Resultados -->
        <div class="col-lg-8">
            <div class="content-card h-100">
                <h4 class="mb-4 text-white"><i class="bi bi-cpu me-2"></i>Análisis de Resultados</h4>

                @if (SumaIndices > 0)
                {
                    <!-- Resumen de Variables Principales -->
                    <div class="row mb-4 g-3">
                        <div class="col-md-4">
                            <div class="stat-box text-center">
                                <span class="text-muted d-block mb-1">Monto (M)</span>
                                <h4 class="text-white">@montoTotal.ToString("C0", cultureCOP)</h4>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="stat-box text-center">
                                <span class="text-muted d-block mb-1">Total Índices (Σ)</span>
                                <h4 class="text-white">@SumaIndices.ToString("N0")</h4>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="stat-box text-center border-emerald highlight-box">
                                <span class="text-emerald d-block mb-1">Factor (F<sub>c</sub>)</span>
                                <h4 class="text-emerald fw-bold">@Fc.ToString("N6")</h4>
                            </div>
                        </div>
                    </div>

                    <!-- Tabla de Distribución -->
                    <div class="table-responsive">
                        <table class="table table-dark custom-table">
                            <thead>
                                <tr>
                                    <th class="ps-4">Parte / Sujeto</th>
                                    <th class="text-center">Índice</th>
                                    <th class="text-center">Ecuación Aplicada</th>
                                    <th class="text-end pe-4">Monto Asignado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (ind, idx) in individuos.Select((v, i) => (v, i)))
                                {
                                    <tr>
                                        <td class="ps-4">Sujeto #@(idx + 1)</td>
                                        <td class="text-center"><span class="badge bg-secondary">@ind.Indice</span></td>
                                        <td class="text-center text-muted font-monospace small">
                                            @ind.Indice × @Fc.ToString("N4")
                                        </td>
                                        <td class="text-end pe-4 fw-bold text-emerald">
                                            @CalcularCociente(ind.Indice).ToString("C0", cultureCOP)
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="bg-darker">
                                <tr>
                                    <td colspan="3" class="text-end fw-bold text-muted uppercase tracking-wider">Total Repartido:</td>
                                    <td class="text-end pe-4 fw-bold text-emerald border-top border-emerald fs-5">
                                        @TotalCalculado.ToString("C0", cultureCOP)
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <div class="empty-icon-circle">
                            <i class="bi bi-calculator"></i>
                        </div>
                        <h5 class="text-white">Faltan datos de entrada</h5>
                        <p>Ingrese los valores para proceder con el cálculo.</p>
                    </div>
                }
            </div>
        </div>
    </div>


</div>

@code {
    private double montoTotal = 0;
    private CultureInfo cultureCOP = new CultureInfo("es-CO");

    private List<IndiceItem> individuos = new()
{
    new IndiceItem { Indice = 0 },
    new IndiceItem { Indice = 0 },
    new IndiceItem { Indice = 0 }
};

    public class IndiceItem { public double Indice { get; set; } }

    private void AgregarIndividuo() => individuos.Add(new IndiceItem());
    private void EliminarIndividuo(int index) { if (individuos.Count > 1) individuos.RemoveAt(index); }

    // Lógica del Método 2
    private double SumaIndices => individuos.Sum(i => i.Indice);
    private double Fc => SumaIndices > 0 ? montoTotal / SumaIndices : 0;
    private double CalcularCociente(double indice) => indice * Fc;
    private double TotalCalculado => individuos.Sum(i => CalcularCociente(i.Indice));


}