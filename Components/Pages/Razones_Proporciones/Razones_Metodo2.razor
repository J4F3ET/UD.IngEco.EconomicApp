@page "/razones/metodo-2"
@using System.Globalization
@rendermode InteractiveServer

<div class="animate-fadeIn max-w-7xl mx-auto">
    <div class="flex items-center gap-4 mb-6">
        <a href="razones" class="flex items-center gap-2 text-slate-400 hover:text-emerald-500 transition-colors">
            <i class="bi bi-arrow-left"></i> Volver al Menú
        </a>
        <h3 class="text-emerald-500 font-bold text-xl mb-0">Método 2: Reducción a la Unidad</h3>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
        <div class="lg:col-span-1 space-y-6">
            <div class="card-dark">
                <h4 class="text-white font-semibold mb-4 flex items-center gap-2">
                    <i class="bi bi-input-cursor-text text-emerald-500"></i>
                    Entrada de Datos
                </h4>
                <div class="mb-4">
                    <label class="block text-slate-400 text-xs font-bold uppercase tracking-wider mb-2">Cantidad a Repartir (COP)</label>
                    <div class="flex">
                        <span class="input-dark rounded-r-none px-3 flex items-center bg-slate-800 border-r border-slate-700 text-emerald-500">$</span>
                        <input type="number" class="input-dark rounded-l-none" @bind="montoTotal" @bind:event="oninput" placeholder="Ej: 450000" />
                    </div>
                </div>

                <div class="flex justify-between items-center mb-3">
                    <label class="text-slate-400 text-xs font-bold uppercase tracking-wider">Índices de Reparto</label>
                    <button class="bg-emerald-500/10 text-emerald-500 px-3 py-1 rounded-lg text-sm font-semibold hover:bg-emerald-500/20 transition-colors flex items-center gap-1" @onclick="AgregarIndividuo">
                        <i class="bi bi-plus-lg"></i> Nuevo
                    </button>
                </div>

                <div class="max-h-64 overflow-y-auto pr-2 space-y-2">
                    @for (int i = 0; i < individuos.Count; i++)
                    {
                        var index = i;
                        <div class="flex gap-2 animate-fadeIn">
                            <span class="input-dark rounded-r-none px-3 flex items-center bg-slate-800 border-r border-slate-700 text-slate-500 text-sm">ID @(index + 1)</span>
                            <input type="number" class="input-dark flex-1" @bind="individuos[index].Indice" @bind:event="oninput" placeholder="Valor" />
                            <button class="bg-red-500/10 text-red-500 px-3 rounded-lg hover:bg-red-500/20 transition-colors" @onclick="() => EliminarIndividuo(index)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    }
                </div>
            </div>

            <div class="card-dark border-l-4 border-l-emerald-500">
                <h5 class="text-emerald-500 font-semibold mb-4 text-center">Formulas Implementadas</h5>
                <div class="space-y-4">
                    <div>
                        <div class="text-slate-500 text-xs font-bold uppercase tracking-wider mb-2">Factor de Conversión:</div>
                        <div class="bg-slate-800/50 p-3 rounded-lg font-mono text-sm">
                            <span class="text-emerald-500">Fc</span> = Monto / Σ Índices
                        </div>
                    </div>
                    <div>
                        <div class="text-slate-500 text-xs font-bold uppercase tracking-wider mb-2">Cociente Individual:</div>
                        <div class="bg-slate-800/50 p-3 rounded-lg font-mono text-sm">
                            <span class="text-emerald-500">Cn</span> = Índice × Fc
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-3">
            <div class="card-dark h-full">
                <h4 class="text-white font-semibold mb-4 flex items-center gap-2">
                    <i class="bi bi-cpu text-emerald-500"></i>
                    Análisis de Resultados
                </h4>

                @if (SumaIndices > 0)
                {
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                        <div class="bg-slate-800 p-4 rounded-xl border border-slate-700 text-center">
                            <span class="text-slate-500 text-xs font-bold uppercase tracking-wider block mb-1">Monto (M)</span>
                            <h4 class="text-white font-bold">@montoTotal.ToString("C0", cultureCOP)</h4>
                        </div>
                        <div class="bg-slate-800 p-4 rounded-xl border border-slate-700 text-center">
                            <span class="text-slate-500 text-xs font-bold uppercase tracking-wider block mb-1">Total Índices (Σ)</span>
                            <h4 class="text-white font-bold">@SumaIndices.ToString("N0")</h4>
                        </div>
                        <div class="bg-emerald-500/10 p-4 rounded-xl border border-emerald-500 text-center">
                            <span class="text-emerald-500 text-xs font-bold uppercase tracking-wider block mb-1">Factor (Fc)</span>
                            <h4 class="text-emerald-500 font-bold">@Fc.ToString("N6")</h4>
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead>
                                <tr class="border-b border-slate-700">
                                    <th class="text-left py-3 px-4 text-slate-400 text-xs uppercase tracking-wider">Sujeto</th>
                                    <th class="text-center py-3 px-4 text-slate-400 text-xs uppercase tracking-wider">Índice</th>
                                    <th class="text-center py-3 px-4 text-slate-400 text-xs uppercase tracking-wider">Ecuación</th>
                                    <th class="text-right py-3 px-4 text-slate-400 text-xs uppercase tracking-wider">Monto Asignado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (ind, idx) in individuos.Select((v, i) => (v, i)))
                                {
                                    <tr class="border-b border-slate-700/50 hover:bg-emerald-500/5 transition-colors">
                                        <td class="py-3 px-4">Sujeto #@(idx + 1)</td>
                                        <td class="py-3 px-4 text-center">
                                            <span class="bg-slate-700 px-2 py-1 rounded text-sm">@ind.Indice</span>
                                        </td>
                                        <td class="py-3 px-4 text-center text-slate-500 font-mono text-sm">
                                            @ind.Indice × @Fc.ToString("N4")
                                        </td>
                                        <td class="py-3 px-4 text-right font-bold text-emerald-500">
                                            @CalcularCociente(ind.Indice).ToString("C0", cultureCOP)
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="bg-slate-800/50">
                                    <td colspan="3" class="py-3 px-4 text-right font-bold text-slate-400 uppercase tracking-wider">Total Repartido:</td>
                                    <td class="py-3 px-4 text-right font-bold text-emerald-500 text-lg border-t border-emerald-500">
                                        @TotalCalculado.ToString("C0", cultureCOP)
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-16">
                        <div class="w-20 h-20 bg-slate-800 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i class="bi bi-calculator text-3xl text-slate-600"></i>
                        </div>
                        <h5 class="text-white font-semibold mb-2">Faltan datos de entrada</h5>
                        <p class="text-slate-500">Ingrese los valores para proceder con el cálculo.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private double montoTotal = 0;
    private CultureInfo cultureCOP = new CultureInfo("es-CO");

    private List<IndiceItem> individuos = new()
    {
        new IndiceItem { Indice = 0 },
        new IndiceItem { Indice = 0 },
        new IndiceItem { Indice = 0 }
    };

    public class IndiceItem { public double Indice { get; set; } }

    private void AgregarIndividuo() => individuos.Add(new IndiceItem());
    private void EliminarIndividuo(int index) { if (individuos.Count > 1) individuos.RemoveAt(index); }

    private double SumaIndices => individuos.Sum(i => i.Indice);
    private double Fc => SumaIndices > 0 ? montoTotal / SumaIndices : 0;
    private double CalcularCociente(double indice) => indice * Fc;
    private double TotalCalculado => individuos.Sum(i => CalcularCociente(i.Indice));
}