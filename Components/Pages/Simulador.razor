@page "/simulador"
@rendermode InteractiveServer
@inject ITasaService TasaService
@inject IAmortizacionService AmortizacionService
@inject IReporteService ReporteService
@inject IJSRuntime JS
@using EconomicApp.Components.Shared.Simulador

<div class="animate-fadeIn max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-8">
    <div class="mb-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-white flex items-center gap-3 mb-2">
            <i class="bi bi-calculator text-emerald-500"></i>
            Simulador de Créditos
        </h2>
        <p class="text-slate-400 text-sm sm:text-base max-w-2xl">Modele préstamos, convierta tasas y genere tablas de amortización detalladas para sus análisis financieros.</p>
    </div>

    <EditForm Model="@simulacion" OnValidSubmit="SimularCredito" OnInvalidSubmit="SimulacionInvalida">
        <DataAnnotationsValidator />
        
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 items-start">
            <SimuladorDatosCredito Simulacion="@simulacion" />
            <SimuladorTasaInteres Simulacion="@simulacion" />
            <div class="md:col-span-2 xl:col-span-1">
                <SimuladorConfigAmortizacion Amortizacion="@amortizacion" />
            </div>
        </div>
        
        <button type="submit" class="btn-emerald w-full py-4 mt-8 flex items-center justify-center gap-2 text-lg font-semibold transition-all hover:scale-[1.01] active:scale-[0.99] shadow-lg shadow-emerald-900/20">
            <i class="bi bi-play-fill text-xl"></i>
            Simular Crédito
        </button>
    </EditForm>

    <div class="mt-6">
        <SimuladorTasaAlert ConversionTasa="@conversionTasa" />
    </div>

    @if (resultadoAmortizacion != null)
    {
        <div class="mt-10 space-y-10 animate-fadeIn">
            <SimuladorResumen Resultado="@resultadoAmortizacion" Monto="@simulacion.MontoPrestamo" />
            <div class="bg-slate-800/50 rounded-xl overflow-hidden shadow-xl border border-slate-700/50">
                <SimuladorTabla Cuotas="@resultadoAmortizacion.TablaAmortizacion" OnExport="Exportar" />
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="alert-danger mt-4 flex items-center gap-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            @mensajeError
        </div>
    }
</div>

@code {
    private SimulacionRequestDto simulacion = new() 
    { 
        FrecuenciaPago = Frecuencia.Mensual, 
        FrecuenciaTasa = Frecuencia.Anual
    };
    private AmortizacionRequestDto amortizacion = new() { SistemaAmortizacion = SistemaAmortizacion.Frances };
    private ConversionTasaResponseDto? conversionTasa;
    private AmortizacionResponseDto? resultadoAmortizacion;
    private string mensajeError = string.Empty;

    private void SimulacionInvalida()
    {
        mensajeError = "Por favor, corrija los errores en el formulario antes de simular.";
        conversionTasa = null;
        resultadoAmortizacion = null;
    }

    private void SimularCredito()
    {
        mensajeError = string.Empty;
        conversionTasa = null;
        resultadoAmortizacion = null;
        StateHasChanged();
        try
        {
            conversionTasa = TasaService.CalcularTasaPeriodica(simulacion);
            if (!conversionTasa.EsExitoso)
            {
                mensajeError = conversionTasa.Mensaje;
                return;
            }

            amortizacion.Capital = simulacion.MontoPrestamo;
            amortizacion.Plazo = simulacion.Plazo;
            amortizacion.TasaEfectivaPeriodica = conversionTasa.TasaEfectivaPeriodica;

            resultadoAmortizacion = AmortizacionService.GenerarTabla(amortizacion);
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al simular: {ex.Message}";
        }
    }

    private async Task Exportar(FormatoExportacion formato)
    {
        if (resultadoAmortizacion == null || conversionTasa == null) return;

        try
        {
            byte[] archivo;
            string extension;

            if (formato == FormatoExportacion.Excel)
            {
                archivo = ReporteService.GenerarReporteExcel(resultadoAmortizacion, simulacion);
                extension = "csv";
            }
            else
            {
                archivo = ReporteService.GenerarReportePdf(resultadoAmortizacion, simulacion);
                extension = "txt";
            }

            var nombreArchivo = $"reporte_credito_{DateTime.Now:yyyyMMddHHmmss}.{extension}";
            await JS.InvokeVoidAsync("downloadFileFromBytes", nombreArchivo, archivo);
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al exportar: {ex.Message}";
        }
    }
}