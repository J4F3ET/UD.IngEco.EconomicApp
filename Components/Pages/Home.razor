@page "/"

<div class="welcome-container">
    <div class="hero-card">
        <h1 class="display-4 fw-bold">Bienvenido al Portal de <span class="text-emerald">Ingeniería Económica</span></h1>
        <p class="lead text-muted">Automatiza tus cálculos financieros con precisión profesional.</p>
    </div>

    <div class="modules-grid">
        <div class="m-card">
            <i class="bi bi-arrow-left-right"></i>
            <h3>Razones y Proporciones</h3>
            <p>Análisis de relaciones numéricas y comparativas.</p>
            <a href="razones" class="btn-module">Abrir Módulo</a>
        </div>

        <div class="m-card">
            <i class="bi bi-percent"></i>
            <h3>Interés Simple</h3>
            <p>Cálculo de rendimientos sobre capital inicial.</p>
            <a href="interes-simple" class="btn-module">Calcular</a>
        </div>

        <div class="m-card">
            <i class="bi bi-piggy-bank"></i>
            <h3>Interés Compuesto</h3>
            <p>Efecto de la capitalización en el tiempo.</p>
            <a href="interes-compuesto" class="btn-module">Simular</a>
        </div>
    </div>
</div>
