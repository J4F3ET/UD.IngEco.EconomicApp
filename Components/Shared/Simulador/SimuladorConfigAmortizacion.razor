@using EconomicApp.Models.DTOs

<div class="card-dark h-full">
    <h5 class="text-emerald-500 font-semibold mb-4 flex items-center gap-2">
        <i class="bi bi-gear"></i>
        Configuración de Amortización
    </h5>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2 gap-6">
        <div>
            <label class="block text-sm font-medium text-slate-400 mb-3">Sistema de Amortización</label>
            <div class="flex flex-wrap gap-4 sm:gap-6">
                <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="sistema" class="w-4 h-4 accent-emerald-500" 
                        checked="@(Amortizacion.SistemaAmortizacion == SistemaAmortizacion.Frances)"
                        @onclick="@(() => Amortizacion.SistemaAmortizacion = SistemaAmortizacion.Frances)" />
                    <span class="text-white flex items-center gap-1">
                        <i class="bi bi-calendar-check text-emerald-500"></i>
                        Francés
                    </span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="sistema" class="w-4 h-4 accent-emerald-500"
                        checked="@(Amortizacion.SistemaAmortizacion == SistemaAmortizacion.Aleman)"
                        @onclick="@(() => Amortizacion.SistemaAmortizacion = SistemaAmortizacion.Aleman)" />
                    <span class="text-white flex items-center gap-1">
                        <i class="bi bi-cash-stack text-emerald-500"></i>
                        Alemán
                    </span>
                </label>
            </div>
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-400 mb-2">Periodos de Gracia (g)</label>
            <InputNumber class="input-dark" @bind-Value="Amortizacion.PeriodosGracia" min="0" max="60" placeholder="0" />
            <ValidationMessage For="@(() => Amortizacion.PeriodosGracia)" class="text-red-500 text-xs mt-1" />
            <small class="text-slate-500 text-xs">Intereses capitalizados al capital</small>
        </div>
    </div>
</div>

@code {
    [Parameter] public AmortizacionRequestDto Amortizacion { get; set; } = new();
}