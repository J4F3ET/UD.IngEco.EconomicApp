@using EconomicApp.Models.DTOs

<div class="card-dark">
    <div class="flex justify-between items-center mb-4">
        <h5 class="text-emerald-500 font-semibold flex items-center gap-2">
            <i class="bi bi-table"></i>
            Tabla de Amortización
        </h5>
        <div class="flex gap-2">
            <button class="bg-emerald-500 text-slate-900 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-emerald-400 transition-colors flex items-center gap-2"
                @onclick="() => OnExport.InvokeAsync(FormatoExportacion.Excel)">
                <i class="bi bi-file-excel"></i>
                Excel
            </button>
            <button class="bg-red-500 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-red-400 transition-colors flex items-center gap-2"
                @onclick="() => OnExport.InvokeAsync(FormatoExportacion.PDF)">
                <i class="bi bi-file-pdf"></i>
                PDF
            </button>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-slate-700">
                    <th class="text-left py-3 px-4 text-emerald-500 text-xs uppercase tracking-wider font-semibold">Periodo</th>
                    <th class="text-right py-3 px-4 text-emerald-500 text-xs uppercase tracking-wider font-semibold">Saldo Inicial</th>
                    <th class="text-right py-3 px-4 text-emerald-500 text-xs uppercase tracking-wider font-semibold">Interés</th>
                    <th class="text-right py-3 px-4 text-emerald-500 text-xs uppercase tracking-wider font-semibold">Abono Capital</th>
                    <th class="text-right py-3 px-4 text-emerald-500 text-xs uppercase tracking-wider font-semibold">Cuota</th>
                    <th class="text-right py-3 px-4 text-emerald-500 text-xs uppercase tracking-wider font-semibold">Saldo Final</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cuota in Cuotas)
                {
                    <tr class="border-b border-slate-700/50 hover:bg-emerald-500/5 transition-colors">
                        <td class="py-3 px-4 text-center font-bold">@cuota.NumeroPeriodo</td>
                        <td class="py-3 px-4 text-right">@cuota.SaldoInicial.ToString("N2")</td>
                        <td class="py-3 px-4 text-right">@cuota.Interes.ToString("N2")</td>
                        <td class="py-3 px-4 text-right">@cuota.AbonoCapital.ToString("N2")</td>
                        <td class="py-3 px-4 text-right font-bold">@cuota.ValorCuota.ToString("N2")</td>
                        <td class="py-3 px-4 text-right">@cuota.SaldoFinal.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter] public List<CuotaDto> Cuotas { get; set; } = new();
    [Parameter] public EventCallback<FormatoExportacion> OnExport { get; set; }
}