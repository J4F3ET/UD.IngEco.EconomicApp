@using EconomicApp.Models.DTOs
@using System.Globalization

<div class="bg-slate-800 rounded-xl p-4 sm:p-6 border border-slate-700/50">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
        <h5 class="text-emerald-500 font-semibold flex items-center gap-2">
            <i class="bi bi-table"></i>
            Tabla de Amortización
        </h5>
        <div class="flex gap-2 w-full sm:w-auto">
            <button class="bg-emerald-500 text-slate-900 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-emerald-400 transition-colors flex items-center gap-2 flex-1 sm:flex-none justify-center"
                @onclick="() => OnExport.InvokeAsync(FormatoExportacion.Excel)">
                <i class="bi bi-file-excel"></i>
                <span class="hidden sm:inline">Excel</span>
            </button>
            <button class="bg-red-500 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-red-400 transition-colors flex items-center gap-2 flex-1 sm:flex-none justify-center"
                @onclick="() => OnExport.InvokeAsync(FormatoExportacion.PDF)">
                <i class="bi bi-file-pdf"></i>
                <span class="hidden sm:inline">PDF</span>
            </button>
        </div>
    </div>

    <div class="overflow-x-auto -mx-4 sm:mx-0 custom-scrollbar">
        <table class="w-full min-w-[600px]">
            <thead>
                <tr class="border-b border-slate-700">
                    <th class="text-center py-3 px-2 sm:px-4 text-emerald-500 text-xs uppercase tracking-wider font-semibold">Periodo</th>
                    <th class="text-right py-3 px-2 sm:px-4 text-emerald-500 text-xs uppercase tracking-wider font-semibold">Saldo</th>
                    <th class="text-right py-3 px-2 sm:px-4 text-emerald-500 text-xs uppercase tracking-wider font-semibold">Interés</th>
                    <th class="text-right py-3 px-2 sm:px-4 text-emerald-500 text-xs uppercase tracking-wider font-semibold">Cuota</th>
                    <th class="text-right py-3 px-2 sm:px-4 text-emerald-500 text-xs uppercase tracking-wider font-semibold">Amortización</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cuota in Cuotas)
                {
                    var esUltimaFila = cuota == Cuotas.Last();
                    <tr class="border-b border-slate-700/30 hover:bg-emerald-500/5 transition-colors @(cuota.NumeroPeriodo == 0 ? "bg-emerald-500/5" : "") @(esUltimaFila ? "bg-red-500/10" : "")">
                        <td class="py-3 px-2 sm:px-4 text-center font-bold text-sm">@cuota.NumeroPeriodo</td>
                        <td class="py-3 px-2 sm:px-4 text-right text-sm text-slate-300">@Formatear(ObtenerSaldo(cuota))</td>
                        <td class="py-3 px-2 sm:px-4 text-right text-sm text-slate-300">@Formatear(cuota.Interes)</td>
                        <td class="py-3 px-2 sm:px-4 text-right font-bold text-emerald-500 text-sm">@Formatear(cuota.ValorCuota)</td>
                        <td class="py-3 px-2 sm:px-4 text-right text-sm text-slate-300">@Formatear(cuota.AbonoCapital)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter] public List<CuotaDto> Cuotas { get; set; } = new();
    [Parameter] public EventCallback<FormatoExportacion> OnExport { get; set; }

    private decimal ObtenerSaldo(CuotaDto cuota)
    {
        return cuota.SaldoFinal;
    }

    private string Formatear(decimal valor)
    {
        return valor.ToString("N2", CultureInfo.CreateSpecificCulture("es-CO"));
    }
}