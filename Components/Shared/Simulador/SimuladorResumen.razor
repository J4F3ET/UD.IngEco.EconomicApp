@using EconomicApp.Models.DTOs

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="card-dark text-center">
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Total Intereses</div>
        <h3 class="text-2xl font-bold text-emerald-500">@Resultado.TotalInteresesPagados.ToString("C")</h3>
    </div>
    <div class="card-dark text-center">
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Total Pagado</div>
        <h3 class="text-2xl font-bold text-white">@Resultado.TotalPagado.ToString("C")</h3>
    </div>
    <div class="card-dark text-center">
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Costo Financiero</div>
        <h3 class="text-2xl font-bold text-red-500">@((Resultado.TotalPagado - Monto).ToString("C"))</h3>
    </div>
</div>

@code {
    [Parameter] public AmortizacionResponseDto Resultado { get; set; } = new();
    [Parameter] public decimal Monto { get; set; }
}