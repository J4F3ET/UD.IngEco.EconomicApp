@inject NavigationManager NavigationManager

<nav class="bg-slate-900 border-b border-slate-800 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <div class="flex items-center gap-8">
                <a href="/" class="flex items-center gap-2 group">
                    <div class="w-8 h-8 bg-emerald-500/10 rounded flex items-center justify-center group-hover:bg-emerald-500/20 transition-colors">
                        <i class="bi bi-graph-up text-emerald-500"></i>
                    </div>
                    <span class="text-white font-bold text-xl tracking-tight group-hover:text-emerald-400 transition-colors">EconomicApp</span>
                </a>
                
                <div class="hidden md:flex items-center gap-2">
                    <NavLink href="/" Match="NavLinkMatch.All" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-emerald-500 hover:bg-emerald-500/5 transition-all flex items-center gap-2" ActiveClass="text-emerald-500 bg-emerald-500/10">
                        <i class="bi bi-house"></i> Inicio
                    </NavLink>
                    <NavLink href="/simulador" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-emerald-500 hover:bg-emerald-500/5 transition-all flex items-center gap-2" ActiveClass="text-emerald-500 bg-emerald-500/10">
                        <i class="bi bi-calculator"></i> Simulador
                    </NavLink>
                    <NavLink href="/razones" class="px-3 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-emerald-500 hover:bg-emerald-500/5 transition-all flex items-center gap-2" ActiveClass="text-emerald-500 bg-emerald-500/10">
                        <i class="bi bi-arrow-left-right"></i> Razones
                    </NavLink>
                </div>
            </div>
            
            <div class="flex items-center gap-4">
                <div class="hidden sm:flex flex-col items-end">
                    <span class="text-[10px] text-slate-500 font-mono uppercase tracking-widest leading-none">Ingeniería</span>
                    <span class="text-[10px] text-emerald-500 font-mono uppercase tracking-widest font-bold leading-none">Económica</span>
                </div>
                <div class="h-8 w-[1px] bg-slate-800 hidden sm:block"></div>
                <a href="https://github.com/J4F3ET/UD.IngEco.EconomicApp" target="_blank" class="text-slate-400 hover:text-white transition-colors" title="Ver en GitHub">
                    <i class="bi bi-github text-xl"></i>
                </a>
            </div>
        </div>
    </div>
</nav>

@code { }